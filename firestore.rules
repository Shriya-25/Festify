rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check user role (safe - handles missing data)
    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == role;
    }
    
    // Users collection rules
    match /users/{userId} {
      // Allow users to read their own document
      allow read: if isOwner(userId);
      
      // Allow authenticated users to create their own document
      allow create: if isOwner(userId);
      
      // Allow users to update their own document
      allow update: if isOwner(userId);
      
      // Admins can read and write all users
      allow read, write: if hasRole('admin');
    }
    
    // Fests collection rules
    match /fests/{festId} {
      // Anyone (even unauthenticated) can read published fests
      allow read: if true;
      
      // Only organizers can create fests
      allow create: if hasRole('organizer') || hasRole('admin');
      
      // Organizers can update their own fests, admins can update any
      allow update: if (hasRole('organizer') && resource.data.organizerId == request.auth.uid) 
                    || hasRole('admin');
      
      // Only admins can delete fests
      allow delete: if hasRole('admin');
    }
    
    // Registrations collection rules
    match /registrations/{registrationId} {
      // Users can read their own registrations
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Students can create registrations
      allow create: if hasRole('student') && request.resource.data.userId == request.auth.uid;
      
      // Users can update their own registrations
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can delete their own registrations
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Organizers can read registrations for their fests
      allow read: if hasRole('organizer');
      
      // Admins have full access
      allow read, write: if hasRole('admin');
    }
    
    // Events collection rules
    match /events/{eventId} {
      // Anyone can read events
      allow read: if true;
      
      // Only organizers can create events
      allow create: if hasRole('organizer') || hasRole('admin');
      
      // Organizers can update their own events, admins can update any
      allow update: if hasRole('organizer') || hasRole('admin');
      
      // Allow students to increment participantCount only (for registration)
      allow update: if isAuthenticated() && 
                      hasRole('student') &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantCount']) &&
                      request.resource.data.participantCount == resource.data.participantCount + 1;
      
      // Only admins can delete events
      allow delete: if hasRole('admin');
    }
    
    // Event Registrations collection rules
    match /eventRegistrations/{registrationId} {
      // Users can read their own registrations
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Students can create registrations (with deadline validation in app logic)
      allow create: if hasRole('student') && request.resource.data.userId == request.auth.uid;
      
      // Users can update their own registrations
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can delete their own registrations
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Organizers can read all event registrations (for their events)
      allow read: if hasRole('organizer');
      
      // Admins have full access
      allow read, write: if hasRole('admin');
    }
  }
}